{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OpenTax Obsidian Node",
  "type": "object",
  "required": [
    "id",
    "title",
    "type",
    "description",
    "parents",
    "children",
    "related",
    "terms",
    "deadlines",
    "sources",
    "tags"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "enum": [
        "domain",
        "category",
        "tax",
        "deduction",
        "tax-credit",
        "tax-reduction",
        "corporate-tax-support",
        "support-program",
        "filing",
        "scenario",
        "concept",
        "term",
        "deadline",
        "source"
      ]
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "basis_year": {
      "type": [
        "integer",
        "null"
      ]
    },
    "effective_date": {
      "type": [
        "string",
        "null"
      ]
    },
    "expiration_date": {
      "type": [
        "string",
        "null"
      ]
    },
    "parents": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "children": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "related": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "terms": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "deadlines": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "criteria": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "label",
          "basis",
          "condition",
          "source"
        ],
        "properties": {
          "label": {
            "type": "string",
            "minLength": 1
          },
          "basis": {
            "type": "string",
            "minLength": 1
          },
          "condition": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "type": "string",
            "minLength": 1
          },
          "law_reference": {
            "type": "string"
          },
          "criteria_kind": {
            "type": "string",
            "enum": [
              "threshold",
              "rate",
              "limit",
              "deduction",
              "formula",
              "eligibility",
              "deadline",
              "period",
              "person",
              "reference"
            ]
          },
          "basis_category": {
            "type": "string"
          },
          "basis_definition": {
            "type": "string"
          },
          "basis_lookup": {
            "type": "string"
          },
          "selection_rule": {
            "type": "string"
          },
          "basis_source": {
            "type": "string"
          },
          "threshold_krw": {
            "type": "integer",
            "minimum": 0
          },
          "threshold_krw_min": {
            "type": "integer",
            "minimum": 0
          },
          "threshold_krw_max": {
            "type": "integer",
            "minimum": 0
          },
          "amount_krw": {
            "type": "integer",
            "minimum": 0
          },
          "max_amount_krw": {
            "type": "integer",
            "minimum": 0
          },
          "deduction_krw": {
            "type": "integer",
            "minimum": 0
          },
          "base_deduction_krw": {
            "type": "integer",
            "minimum": 0
          },
          "per_year_deduction_krw": {
            "type": "integer",
            "minimum": 0
          },
          "limit_krw": {
            "type": "integer",
            "minimum": 0
          },
          "progressive_deduction_krw": {
            "type": "integer",
            "minimum": 0
          },
          "rate_percent": {
            "type": "number",
            "minimum": 0
          },
          "rate_percent_min": {
            "type": "number",
            "minimum": 0
          },
          "rate_percent_max": {
            "type": "number",
            "minimum": 0
          },
          "rate_label": {
            "type": "string"
          },
          "rate_basis": {
            "type": "string"
          },
          "amount_formula": {
            "type": "string"
          },
          "amount_applicability": {
            "type": "string"
          },
          "unlimited_amount": {
            "type": "boolean"
          },
          "benefit": {
            "type": "string"
          },
          "note": {
            "type": "string"
          },
          "age_min": {
            "type": "integer",
            "minimum": 0
          },
          "age_max": {
            "type": "integer",
            "minimum": 0
          },
          "household_size": {
            "type": "integer",
            "minimum": 1
          },
          "median_income_percent_max": {
            "type": "number",
            "minimum": 0
          },
          "period_years": {
            "type": "integer",
            "minimum": 0
          },
          "period_years_min": {
            "type": "integer",
            "minimum": 0
          },
          "period_years_max": {
            "type": "integer",
            "minimum": 0
          },
          "period_months_min": {
            "type": "integer",
            "minimum": 0
          },
          "period_months_max": {
            "type": "integer",
            "minimum": 0
          },
          "years_of_service_min": {
            "type": "integer",
            "minimum": 0
          },
          "years_of_service_max": {
            "type": "integer",
            "minimum": 0
          },
          "deadline_month": {
            "type": "integer",
            "minimum": 1,
            "maximum": 12
          },
          "deadline_day": {
            "type": "integer",
            "minimum": 1,
            "maximum": 31
          },
          "deadline_start_month": {
            "type": "integer",
            "minimum": 1,
            "maximum": 12
          },
          "deadline_start_day": {
            "type": "integer",
            "minimum": 1,
            "maximum": 31
          },
          "deadline_end_month": {
            "type": "integer",
            "minimum": 1,
            "maximum": 12
          },
          "deadline_end_day": {
            "type": "integer",
            "minimum": 1,
            "maximum": 31
          },
          "deadline_days_after_event": {
            "type": "integer",
            "minimum": 0
          },
          "deadline_months_after_month_end": {
            "type": "integer",
            "minimum": 0
          },
          "deadline_months_after_month_end_min": {
            "type": "integer",
            "minimum": 0
          },
          "deadline_months_after_month_end_max": {
            "type": "integer",
            "minimum": 0
          },
          "deadline_relative": {
            "type": "string"
          },
          "deadline_rule": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "law_reference": {
      "type": "string"
    },
    "recurrence": {
      "type": "object",
      "properties": {
        "frequency": {
          "type": "string",
          "enum": [
            "annual",
            "semiannual",
            "quarterly",
            "monthly",
            "event-based",
            "one-time"
          ]
        },
        "anchor": {
          "type": "string"
        },
        "period": {
          "type": "string"
        },
        "start_rule": {
          "type": "string"
        },
        "due_rule": {
          "type": "string"
        },
        "special_rule": {
          "type": "string"
        },
        "example": {
          "type": "string"
        }
      },
      "required": [
        "frequency",
        "anchor",
        "due_rule"
      ],
      "additionalProperties": false
    },
    "path_steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "order",
          "label",
          "target",
          "reason"
        ],
        "properties": {
          "order": {
            "type": "integer",
            "minimum": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "target": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "publisher": {
      "type": "string"
    },
    "url": {
      "type": "string"
    },
    "basis_date": {
      "type": "string"
    },
    "start_date": {
      "type": [
        "string",
        "null"
      ]
    },
    "end_date": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
